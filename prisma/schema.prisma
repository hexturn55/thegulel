// Gulel OTT - Vertical Micro Drama Streaming Platform
// Prisma Schema for PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  supabaseId  String?  @unique // Supabase Auth user ID (null for legacy phone-only users)
  phone       String?  @unique // Optional for OAuth users
  email       String?  @unique
  name        String?
  avatar      String?
  locale      String   @default("en")
  provider    String?  // "google" | "facebook" | "line" | "phone" | null
  coinBalance Int      @default(0)
  role        String   @default("user") // "user" | "admin" | "superadmin"
  banned      Boolean  @default(false)
  banReason   String?
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coinTransactions  CoinTransaction[]
  episodePurchases  EpisodePurchase[]
  subscriptions     Subscription[]
  watchHistory      WatchHistory[]

  @@index([phone])
  @@index([email])
  @@index([supabaseId])
}

enum SeriesStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Series {
  id              String        @id @default(cuid())
  title           String
  titleHi         String?
  titleZh         String?
  description     String        @db.Text
  descriptionHi   String?       @db.Text
  descriptionZh   String?       @db.Text
  thumbnail       String
  genre           String
  tags            String[]      @default([])
  totalEpisodes   Int           @default(0)
  freeEpisodes    Int           @default(5)
  coinPrice       Int           @default(10)
  status          SeriesStatus  @default(DRAFT)
  featured        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  episodes        Episode[]

  @@index([status, featured])
  @@index([genre])
}

model Episode {
  id              String   @id @default(cuid())
  seriesId        String
  episodeNumber   Int
  title           String
  titleHi         String?
  titleZh         String?
  duration        Int      // in seconds
  videoUrl        String
  videoId         String   // Cloudflare Stream video ID
  thumbnail       String
  subtitlesEn     String?
  subtitlesHi     String?
  subtitlesZh     String?
  isFree          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  series          Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  purchases       EpisodePurchase[]
  watchHistory    WatchHistory[]

  @@unique([seriesId, episodeNumber])
  @@index([seriesId])
  @@index([isFree])
}

enum TransactionType {
  PURCHASE
  AD_REWARD
  EPISODE_UNLOCK
  SUBSCRIPTION
  BONUS
}

model CoinTransaction {
  id          String          @id @default(cuid())
  userId      String
  amount      Int
  type        TransactionType
  description String?
  createdAt   DateTime        @default(now())

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model EpisodePurchase {
  id          String   @id @default(cuid())
  userId      String
  episodeId   String
  coinsSpent  Int
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode     Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId])
  @@index([episodeId])
}

enum SubscriptionPlan {
  WEEKLY
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model Subscription {
  id          String              @id @default(cuid())
  userId      String
  plan        SubscriptionPlan
  provider    String              // "stripe" or "razorpay"
  providerId  String              // subscription ID from payment provider
  status      SubscriptionStatus  @default(ACTIVE)
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([endDate])
}

model WatchHistory {
  id          String   @id @default(cuid())
  userId      String
  episodeId   String
  progress    Int      // in seconds
  completed   Boolean  @default(false)
  watchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode     Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId, watchedAt])
}

model CoinPackage {
  id          String   @id @default(cuid())
  name        String
  coins       Int
  priceUSD    Float
  priceINR    Float
  popular     Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, popular])
}

model AdCooldown {
  id        String   @id @default(cuid())
  userId    String   @unique
  lastAdAt  DateTime @default(now())

  @@index([userId])
}

model SearchLog {
  id        String   @id @default(cuid())
  query     String
  userId    String?
  results   Int      @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}
