# Database
DATABASE_URL="postgresql://user:password@host:5432/gulel_ott"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Cloudflare Stream
CLOUDFLARE_ACCOUNT_ID="your-account-id"
CLOUDFLARE_API_TOKEN="your-api-token"
NEXT_PUBLIC_CLOUDFLARE_CUSTOMER_SUBDOMAIN="your-subdomain.cloudflarestream.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Razorpay (India payments — optional; INR falls back to Stripe if unset)
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."

# RevenueCat (mobile in-app purchases — App Store / Play Store)
# Webhook authorization value: set this to the exact "Authorization" header
# value configured in the RevenueCat dashboard (it is sent verbatim).
REVENUECAT_WEBHOOK_SECRET="set-a-long-random-string"

# Ads (Google IMA rewarded video — optional; falls back to simulated reward if unset)
# VAST/VMAP ad tag URL from Google Ad Manager for the rewarded "Watch Ad to Earn Coins" flow.
NEXT_PUBLIC_IMA_REWARDED_AD_TAG_URL=""

# SMS/OTP Provider (Twilio example)
TWILIO_ACCOUNT_SID="your-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# JWT
JWT_SECRET="your-jwt-secret-key-minimum-32-characters-long"

# CORS — comma-separated origins allowed to call the JSON API cross-origin
# (e.g. the Expo web preview). Native mobile needs nothing here. Leave empty
# for same-origin only. Example: "http://localhost:8081,https://app.gulel.com"
CORS_ALLOWED_ORIGINS=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Gulel OTT"

# Admin
ADMIN_PHONE="+919876543210"

# Site health audit cron (/api/cron/audit, scheduled in vercel.json)
# CRON_SECRET secures the endpoint — Vercel Cron sends it as a Bearer token.
CRON_SECRET="generate-a-long-random-string"
# Optional: POST a summary to Slack/Discord when the audit finds errors.
AUDIT_WEBHOOK_URL=""
