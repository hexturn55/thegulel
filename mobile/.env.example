# Gulel mobile (Expo) environment.
# Copy to `.env`. Only EXPO_PUBLIC_* vars are exposed to the app bundle.

# Base URL of the deployed Gulel web/API (Next.js app).
EXPO_PUBLIC_API_URL="https://app.gulel.com"

# Supabase (same project as the web app; use the anon/public key here).
EXPO_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# RevenueCat public SDK keys (App Store / Play Store IAP).
EXPO_PUBLIC_RC_IOS_KEY="appl_..."
EXPO_PUBLIC_RC_ANDROID_KEY="goog_..."
